generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String
  role              Role      @default(BDM)
  active            Boolean   @default(true)
  defaultPassword   Boolean   @default(false)
  employeeCode      String?   @unique @default(cuid())
  businessId        String?
  business          Business? @relation(fields: [businessId], references: [id])
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leads             Lead[]
  createdLeads      Lead[]    @relation("LeadCreator")
  tasks             Task[]
  onboarding        OnboardingSession?
  activityLogs      ActivityLog[]
  leadActivities    LeadActivity[]
  reminders         Reminder[]
  dailyBriefs       DailyBrief[]
  callLogs          CallLog[]
  targets           Target[]
  emailAccounts     EmailAccount[]
  bugsReported      Bug[]        @relation("BugReporter")
  bugsAssigned      Bug[]        @relation("BugAssignee")
  escalationsRaised Escalation[] @relation("EscalationRaiser")
  escalationsResolved Escalation[] @relation("EscalationResolver")
  passwordResets    PasswordResetRequest[] @relation("UserPasswordResets")
  resetRequestsMade PasswordResetRequest[] @relation("ResetRequester")
  bdeCommissions    Commission[]       @relation("BDECommissions")
  slabAchievements  SlabAchievement[]
  customerPortfolio CustomerPortfolio[]
  payoutHistory     PayoutHistory[]
  bdmOnboardingLeads OnboardingLead[] @relation("BDMOnboardingLeads")
  sdeOnboardingLeads OnboardingLead[] @relation("SDEOnboardingLeads")
  bdmOnboardingSessions OnboardingSession[] @relation("BDMSessions")
  sdeOnboardingSessions OnboardingSession[] @relation("SDESessions")
  clarificationsRaised OnboardingClarification[] @relation("ClarificationRaiser")
  clarificationsAnswered OnboardingClarification[] @relation("ClarificationAnswerer")
  workspaceTemplates WorkspaceTemplate[]
  workspacesBuilt    WorkspaceConfig[]
  accounts          Account[]
  sessions          Session[]
}

enum Role {
  OWNER
  BOSS
  BDM
  SDE
  ADMIN
}

model PasswordResetRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserPasswordResets", fields: [userId], references: [id])
  requestedBy String
  requester   User     @relation("ResetRequester", fields: [requestedBy], references: [id])
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id           String   @id @default(cuid())
  name         String
  type         String
  teamSize     String
  goal         String
  healthScore  Int      @default(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  leads        Lead[]
  invites      TeamInvite[]
  activityLogs ActivityLog[]
  sprints      Sprint[]
  bugs         Bug[]
  escalations  Escalation[]
  integrationHealth IntegrationHealth[]
  nexaMemory       NexaMemory[]
  nexaSchedules    NexaSchedule[]
  snapshots        BusinessSnapshot[]
  nexaActions      NexaAction[]
  emailAccounts    EmailAccount[]
  emails           Email[]
  emailTemplates   EmailTemplate[]
  commissions      Commission[]
  onboardingLead   OnboardingLead?
  trialSubscription TrialSubscription?
  pipelines        Pipeline[]
}

model Lead {
  id            String      @id @default(cuid())
  name          String
  phone         String?
  email         String?
  company       String?
  source        LeadSource  @default(MANUAL)
  status        LeadStatus  @default(NEW)
  score         Int         @default(0)
  scoreReason   String?
  value         Float       @default(0)
  notes         String?
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id])
  assignedTo    String?
  assignee      User?       @relation(fields: [assignedTo], references: [id])
  createdBy     String?
  creator       User?       @relation("LeadCreator", fields: [createdBy], references: [id])
  followUpDate  DateTime?
  lastContactAt DateTime?
  wonAt         DateTime?
  lostAt        DateTime?
  lostReason    String?
  pipelineId    String?
  pipeline      Pipeline?   @relation(fields: [pipelineId], references: [id])
  onboardingSession OnboardingSession?
  activities    LeadActivity[]
  reminders     Reminder[]
  callLogs      CallLog[]
  emails        Email[]
  commission    Commission?
  customerPortfolio CustomerPortfolio? @relation("PortfolioLead")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Commission {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("BDECommissions", fields: [userId], references: [id])
  leadId          String?   @unique
  lead            Lead?     @relation(fields: [leadId], references: [id])
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id])
  type            CommissionType
  planType        String
  dealValue       Float     @default(0)
  commissionAmt   Float
  status          CommissionStatus @default(PENDING)
  month           Int
  year            Int
  paidAt          DateTime?
  clawbackAt      DateTime?
  clawbackReason  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum CommissionType {
  FIRST_SALE
  RENEWAL
  SLAB_BRONZE
  SLAB_SILVER
  SLAB_GOLD
  SLAB_DIAMOND
  ANNUAL_BONUS
}

enum CommissionStatus {
  PENDING
  PAID
  CLAWBACK
  CANCELLED
}

model SlabAchievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  month       Int
  year        Int
  slabName    String
  dealsCount  Int
  bonusAmt    Float
  achievedAt  DateTime @default(now())
  paidAt      DateTime?
  notified    Boolean  @default(false)

  @@unique([userId, month, year])
}

model CustomerPortfolio {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  leadId        String   @unique
  lead          Lead     @relation("PortfolioLead", fields: [leadId], references: [id])
  planType      String
  monthlyValue  Float
  status        PortfolioStatus @default(TRIAL)
  trialEndsAt   DateTime?
  activeSince   DateTime?
  lastRenewalAt DateTime?
  nextRenewalAt DateTime?
  totalEarned   Float    @default(0)
  renewalCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum PortfolioStatus {
  TRIAL
  PAYING
  OVERDUE
  CHURNED
  UPGRADED
}

model PayoutHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  month       Int
  year        Int
  firstSale   Float    @default(0)
  renewal     Float    @default(0)
  slabBonus   Float    @default(0)
  total       Float    @default(0)
  status      String   @default("pending")
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
}

model OnboardingLead {
  id                 String   @id @default(cuid())
  name               String
  email              String
  phone              String
  companyName        String
  employeeCount      String
  businessType       String
  challenge          String?
  source             String   @default("landing_page")
  status             OnboardingLeadStatus @default(NEW)
  assignedBDMId      String?
  assignedBDM        User?    @relation("BDMOnboardingLeads", fields: [assignedBDMId], references: [id])
  bdmNotes           String?
  bdmSubmittedAt     DateTime?
  assignedSDEId      String?
  assignedSDE        User?    @relation("SDEOnboardingLeads", fields: [assignedSDEId], references: [id])
  sdeNotes           String?
  sdeDeliveredAt     DateTime?
  selectedPlan       String?
  trialActivated     Boolean  @default(false)
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  convertedAt        DateTime?
  cancelledAt        DateTime?
  businessId         String?  @unique
  business           Business? @relation(fields: [businessId], references: [id])
  nexaSessionId      String?
  razorpayMandateId  String?
  razorpayCustomerId String?
  workspaceConfig    WorkspaceConfig?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum OnboardingLeadStatus {
  NEW
  BDM_ASSIGNED
  BDM_CONTACTED
  BDM_SUBMITTED
  SDE_BUILDING
  SDE_DELIVERED
  BOSS_PREVIEWING
  TRIAL_ACTIVE
  CONVERTED
  CANCELLED
  LOST
}

model WorkspaceConfig {
  id               String   @id @default(cuid())
  onboardingLeadId String   @unique
  onboardingLead   OnboardingLead @relation(fields: [onboardingLeadId], references: [id])
  businessId       String?
  companyName      String
  products         Json
  teamRoles        Json
  pipelines        Json
  nexaConfig       Json
  customBranding   Json     @default("{}")
  sdeBuiltBy       String
  sdeBuilder       User     @relation(fields: [sdeBuiltBy], references: [id])
  status           String   @default("building")
  deliveredAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TrialSubscription {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  business           Business @relation(fields: [businessId], references: [id])
  plan               String
  trialStartedAt     DateTime
  trialEndsAt        DateTime
  autoPayEnabled     Boolean  @default(false)
  razorpayMandateId  String?
  razorpayCustomerId String?
  status             TrialStatus @default(TRIAL)
  chargedAt          DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  monthlyAmount      Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum TrialStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
  FAILED
}

model NexaOnboardingSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique @default(cuid())
  visitorName  String?
  visitorEmail String?
  visitorPhone String?
  answers      Json     @default("{}")
  step         Int      @default(0)
  completed    Boolean  @default(false)
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Pipeline {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  name        String
  productName String
  color       String   @default("#7C6FFF")
  stages      Json
  visibleTo   Json     @default("[]")
  slaDays     Json     @default("{}")
  isActive    Boolean  @default(true)
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeadSource {
  MANUAL
  WEBSITE
  REFERRAL
  INSTAGRAM
  WHATSAPP
  EMAIL
  COLD_CALL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO
  PROPOSAL
  WON
  LOST
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  note      String
  createdAt DateTime @default(now())
}

model Reminder {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  message     String
  dueAt       DateTime
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model EmailAccount {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  email        String
  provider     String   @default("gmail")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  tokenExpiry  DateTime
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  emails       Email[]

  @@unique([userId, email])
}

model Email {
  id             String       @id @default(cuid())
  accountId      String
  account        EmailAccount @relation(fields: [accountId], references: [id])
  businessId     String
  business       Business     @relation(fields: [businessId], references: [id])
  gmailId        String       @unique
  threadId       String
  from           String
  fromName       String?
  to             String
  subject        String
  snippet        String?
  body           String       @db.Text
  isRead         Boolean      @default(false)
  isStarred      Boolean      @default(false)
  label          EmailLabel   @default(UNCATEGORIZED)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  nexaSummary    String?
  nexaReplyDraft String?      @db.Text
  receivedAt     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum EmailLabel {
  LEAD
  SUPPORT
  SPAM
  INTERNAL
  IMPORTANT
  UNCATEGORIZED
}

model EmailTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  subject    String
  body       String   @db.Text
  category   String
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  assignedTo  String
  assignee    User       @relation(fields: [assignedTo], references: [id])
  sprintId    String?
  sprint      Sprint?    @relation(fields: [sprintId], references: [id])
  storyPoints Int        @default(1)
  blockedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model NexaInsight {
  id         String   @id @default(cuid())
  businessId String
  type       String
  message    String
  action     String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model OnboardingSession {
  id           String   @id @default(cuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id])
  leadId       String?  @unique
  lead         Lead?    @relation(fields: [leadId], references: [id])
  bdmId        String?
  bdm          User?    @relation("BDMSessions", fields: [bdmId], references: [id])
  status       OnboardingSessionStatus @default(COLLECTING)
  completenessScore Int @default(0)
  companyData  Json     @default("{}")
  employeeData Json     @default("[]")
  pipelineData Json     @default("[]")
  operatingRules Json   @default("[]")
  nexaGaps     Json     @default("[]")
  nexaSuggestions Json  @default("[]")
  nexaMessages Json     @default("[]")
  selectedPlan String?
  planReason   String?
  bdmNotes     String?
  summaryGenerated Boolean @default(false)
  summaryText  String?  @db.Text
  summaryJson  Json?
  submittedAt  DateTime?
  sdeId        String?
  sde          User?    @relation("SDESessions", fields: [sdeId], references: [id])
  employees    OnboardingEmployee[]
  clarifications OnboardingClarification[]
  buildStatus  String?
  approvedAt   DateTime?
  approvedBy   String?
  step         Int      @default(0)
  answers      Json     @default("{}")
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum OnboardingSessionStatus {
  COLLECTING
  NEXA_REVIEWING
  GAP_FILLING
  READY
  SUBMITTED
  SDE_BUILDING
  CLARIFICATION_NEEDED
  SDE_APPROVED
  DELIVERED
  TRIAL_ACTIVE
  CONVERTED
  CANCELLED
}

model OnboardingEmployee {
  id               String   @id @default(cuid())
  sessionId        String
  session          OnboardingSession @relation(fields: [sessionId], references: [id])
  name             String
  title            String
  email            String
  phone            String?
  reportsTo        String?
  directReports    Json     @default("[]")
  systemRole       String
  assignedPipelines Json    @default("[]")
  operatingProcedures String? @db.Text
  dailyTasks       Json     @default("[]")
  decisionAuthority Json    @default("[]")
  communicationPrefs Json   @default("{}")
  nexaFlags        Json     @default("[]")
  completeness     Int      @default(0)
  createdAt        DateTime @default(now())
}

model OnboardingClarification {
  id          String   @id @default(cuid())
  sessionId   String
  session     OnboardingSession @relation(fields: [sessionId], references: [id])
  raisedBy    String
  raiser      User     @relation("ClarificationRaiser", fields: [raisedBy], references: [id])
  question    String   @db.Text
  context     String?
  answeredBy  String?
  answerer    User?    @relation("ClarificationAnswerer", fields: [answeredBy], references: [id])
  answer      String?  @db.Text
  status      String   @default("pending")
  notifiedAt  DateTime?
  answeredAt  DateTime?
  createdAt   DateTime @default(now())
}

model WorkspaceTemplate {
  id           String   @id @default(cuid())
  name         String
  industry     String
  description  String
  config       Json
  usageCount   Int      @default(0)
  createdFrom  String?
  isPublic     Boolean  @default(false)
  createdBy    String
  creator      User     @relation(fields: [createdBy], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamInvite {
  id         String   @id @default(cuid())
  email      String
  name       String
  role       Role     @default(BDM)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  token      String   @unique @default(cuid())
  accepted   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  meta       Json     @default("{}")
  createdAt  DateTime @default(now())
}

model NexaMessage {
  id         String   @id @default(cuid())
  businessId String
  role       String
  content    String
  createdAt  DateTime @default(now())
}

model DailyBrief {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime @default(now())
  tasks      Json
  insights   Json
  greeting   String
  createdAt  DateTime @default(now())
}

model CallLog {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  leadId     String
  lead       Lead        @relation(fields: [leadId], references: [id])
  outcome    CallOutcome
  duration   Int?
  notes      String?
  nextAction String?
  createdAt  DateTime    @default(now())
}

enum CallOutcome {
  ANSWERED_INTERESTED
  ANSWERED_NOT_INTERESTED
  ANSWERED_CALLBACK
  NO_ANSWER
  BUSY
  WRONG_NUMBER
}

model Target {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  month         Int
  year          Int
  leadsTarget   Int      @default(0)
  wonTarget     Int      @default(0)
  revenueTarget Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, month, year])
}

model Sprint {
  id          String       @id @default(cuid())
  businessId  String
  business    Business     @relation(fields: [businessId], references: [id])
  name        String
  goal        String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNING)
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Bug {
  id           String    @id @default(cuid())
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id])
  title        String
  description  String
  severity     Severity  @default(MEDIUM)
  status       BugStatus @default(OPEN)
  reportedBy   String
  reporter     User      @relation("BugReporter", fields: [reportedBy], references: [id])
  assignedTo   String?
  assignee     User?     @relation("BugAssignee", fields: [assignedTo], references: [id])
  stepsToRepro String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

model Escalation {
  id           String           @id @default(cuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id])
  type         EscalationType
  title        String
  description  String
  priority     Priority
  status       EscalationStatus @default(OPEN)
  raisedBy     String
  raiser       User             @relation("EscalationRaiser", fields: [raisedBy], references: [id])
  resolvedBy   String?
  resolver     User?            @relation("EscalationResolver", fields: [resolvedBy], references: [id])
  resolution   String?
  resolvedAt   DateTime?
  notifiedDev  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum EscalationType {
  BUG
  INTEGRATION
  FEATURE_REQUEST
  SECURITY
  PERFORMANCE
  OTHER
}

enum EscalationStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model IntegrationHealth {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  name         String
  type         String
  status       String   @default("unknown")
  lastChecked  DateTime @default(now())
  lastError    String?
  responseTime Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NexaMemory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  key        String
  value      Json
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, key])
}

model NexaSchedule {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  type        String
  cronExpr    String
  lastRanAt   DateTime?
  nextRunAt   DateTime
  enabled     Boolean  @default(true)
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessSnapshot {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])
  date             DateTime @default(now())
  healthScore      Int
  totalLeads       Int
  newLeads         Int
  wonLeads         Int
  lostLeads        Int
  totalRevenue     Float
  teamActivity     Int
  openTasks        Int
  openBugs         Int
  nexaActionsCount Int
  createdAt        DateTime @default(now())
}

model NexaAction {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  type        String
  description String
  payload     Json     @default("{}")
  status      String   @default("completed")
  triggeredBy String   @default("nexa")
  createdAt   DateTime @default(now())
}
