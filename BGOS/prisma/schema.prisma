generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String
  role              Role      @default(BDM)
  businessId        String?
  business          Business? @relation(fields: [businessId], references: [id])
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leads             Lead[]
  tasks             Task[]
  onboarding        OnboardingSession?
  activityLogs      ActivityLog[]
  leadActivities    LeadActivity[]
  reminders         Reminder[]
  dailyBriefs       DailyBrief[]
  callLogs          CallLog[]
  targets           Target[]
  emailAccounts     EmailAccount[]
  bugsReported      Bug[]        @relation("BugReporter")
  bugsAssigned      Bug[]        @relation("BugAssignee")
  escalationsRaised Escalation[] @relation("EscalationRaiser")
  escalationsResolved Escalation[] @relation("EscalationResolver")
}

enum Role {
  BOSS
  BDM
  SDE
  ADMIN
}

model Business {
  id           String   @id @default(cuid())
  name         String
  type         String
  teamSize     String
  goal         String
  healthScore  Int      @default(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  leads        Lead[]
  invites      TeamInvite[]
  activityLogs ActivityLog[]
  sprints      Sprint[]
  bugs         Bug[]
  escalations  Escalation[]
  integrationHealth IntegrationHealth[]
  nexaMemory       NexaMemory[]
  nexaSchedules    NexaSchedule[]
  snapshots        BusinessSnapshot[]
  nexaActions      NexaAction[]
  emailAccounts    EmailAccount[]
  emails           Email[]
  emailTemplates   EmailTemplate[]
}

model Lead {
  id            String      @id @default(cuid())
  name          String
  phone         String?
  email         String?
  company       String?
  source        LeadSource  @default(MANUAL)
  status        LeadStatus  @default(NEW)
  score         Int         @default(0)
  scoreReason   String?
  value         Float       @default(0)
  notes         String?
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id])
  assignedTo    String?
  assignee      User?       @relation(fields: [assignedTo], references: [id])
  followUpDate  DateTime?
  lastContactAt DateTime?
  wonAt         DateTime?
  lostAt        DateTime?
  lostReason    String?
  activities    LeadActivity[]
  reminders     Reminder[]
  callLogs      CallLog[]
  emails        Email[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum LeadSource {
  MANUAL
  WEBSITE
  REFERRAL
  INSTAGRAM
  WHATSAPP
  EMAIL
  COLD_CALL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO
  PROPOSAL
  WON
  LOST
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  note      String
  createdAt DateTime @default(now())
}

model Reminder {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  message     String
  dueAt       DateTime
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model EmailAccount {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  email        String
  provider     String   @default("gmail")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  tokenExpiry  DateTime
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  emails       Email[]

  @@unique([userId, email])
}

model Email {
  id             String       @id @default(cuid())
  accountId      String
  account        EmailAccount @relation(fields: [accountId], references: [id])
  businessId     String
  business       Business     @relation(fields: [businessId], references: [id])
  gmailId        String       @unique
  threadId       String
  from           String
  fromName       String?
  to             String
  subject        String
  snippet        String?
  body           String       @db.Text
  isRead         Boolean      @default(false)
  isStarred      Boolean      @default(false)
  label          EmailLabel   @default(UNCATEGORIZED)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  nexaSummary    String?
  nexaReplyDraft String?      @db.Text
  receivedAt     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum EmailLabel {
  LEAD
  SUPPORT
  SPAM
  INTERNAL
  IMPORTANT
  UNCATEGORIZED
}

model EmailTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  subject    String
  body       String   @db.Text
  category   String
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  assignedTo  String
  assignee    User       @relation(fields: [assignedTo], references: [id])
  sprintId    String?
  sprint      Sprint?    @relation(fields: [sprintId], references: [id])
  storyPoints Int        @default(1)
  blockedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model NexaInsight {
  id         String   @id @default(cuid())
  businessId String
  type       String
  message    String
  action     String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model OnboardingSession {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  step         Int      @default(0)
  answers      Json     @default("{}")
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamInvite {
  id         String   @id @default(cuid())
  email      String
  name       String
  role       Role     @default(BDM)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  token      String   @unique @default(cuid())
  accepted   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  meta       Json     @default("{}")
  createdAt  DateTime @default(now())
}

model NexaMessage {
  id         String   @id @default(cuid())
  businessId String
  role       String
  content    String
  createdAt  DateTime @default(now())
}

model DailyBrief {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime @default(now())
  tasks      Json
  insights   Json
  greeting   String
  createdAt  DateTime @default(now())
}

model CallLog {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  leadId     String
  lead       Lead        @relation(fields: [leadId], references: [id])
  outcome    CallOutcome
  duration   Int?
  notes      String?
  nextAction String?
  createdAt  DateTime    @default(now())
}

enum CallOutcome {
  ANSWERED_INTERESTED
  ANSWERED_NOT_INTERESTED
  ANSWERED_CALLBACK
  NO_ANSWER
  BUSY
  WRONG_NUMBER
}

model Target {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  month         Int
  year          Int
  leadsTarget   Int      @default(0)
  wonTarget     Int      @default(0)
  revenueTarget Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, month, year])
}

model Sprint {
  id          String       @id @default(cuid())
  businessId  String
  business    Business     @relation(fields: [businessId], references: [id])
  name        String
  goal        String?
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNING)
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Bug {
  id           String    @id @default(cuid())
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id])
  title        String
  description  String
  severity     Severity  @default(MEDIUM)
  status       BugStatus @default(OPEN)
  reportedBy   String
  reporter     User      @relation("BugReporter", fields: [reportedBy], references: [id])
  assignedTo   String?
  assignee     User?     @relation("BugAssignee", fields: [assignedTo], references: [id])
  stepsToRepro String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

model Escalation {
  id           String           @id @default(cuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id])
  type         EscalationType
  title        String
  description  String
  priority     Priority
  status       EscalationStatus @default(OPEN)
  raisedBy     String
  raiser       User             @relation("EscalationRaiser", fields: [raisedBy], references: [id])
  resolvedBy   String?
  resolver     User?            @relation("EscalationResolver", fields: [resolvedBy], references: [id])
  resolution   String?
  resolvedAt   DateTime?
  notifiedDev  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum EscalationType {
  BUG
  INTEGRATION
  FEATURE_REQUEST
  SECURITY
  PERFORMANCE
  OTHER
}

enum EscalationStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model IntegrationHealth {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  name         String
  type         String
  status       String   @default("unknown")
  lastChecked  DateTime @default(now())
  lastError    String?
  responseTime Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NexaMemory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  key        String
  value      Json
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, key])
}

model NexaSchedule {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  type        String
  cronExpr    String
  lastRanAt   DateTime?
  nextRunAt   DateTime
  enabled     Boolean  @default(true)
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessSnapshot {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])
  date             DateTime @default(now())
  healthScore      Int
  totalLeads       Int
  newLeads         Int
  wonLeads         Int
  lostLeads        Int
  totalRevenue     Float
  teamActivity     Int
  openTasks        Int
  openBugs         Int
  nexaActionsCount Int
  createdAt        DateTime @default(now())
}

model NexaAction {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  type        String
  description String
  payload     Json     @default("{}")
  status      String   @default("completed")
  triggeredBy String   @default("nexa")
  createdAt   DateTime @default(now())
}
